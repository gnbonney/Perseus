begin
	integer N, M; 
	N := 12; 
	begin 
		integer procedure oneton(N); 
			value N; 
			integer N; 
			begin 
				integer i; 
				for i := 1 step 1 until N do 
					begin 
						outinteger (1, i); 
						outstring (1, “n”); 
					end loop; 
					onetoten := (N * 2); 
			end oneton; 
		M := oneton(N); 
		outinteger(1, M); 
	end all;
end