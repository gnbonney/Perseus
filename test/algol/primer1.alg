begin
      comment Source: E.W. Dijkstra and J.A. Meijer, "A Primer of ALGOL 60
              Programming", Academic Press, 1962.
              https://archive.org/details/a_primer_of_algol_60_programming.;
      real x,y,u;
      x:=5/13;y:=12/13;
      u:=0.6*x-0.8*y;
      y:=0.8*x+0.6*y;
      x:=u
end